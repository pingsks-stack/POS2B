{
  "name": "brew_pos",
  "version": "1.0.0",
  "description": "My premium Nuxt.js project",
  "author": "James_Devfong",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider nuxt",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider nuxt build",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider nuxt start",
    "generate": "cross-env NODE_OPTIONS=--openssl-legacy-provider nuxt generate",
    "build:app": "cross-env NUXT_APP=1 STANDALONE=1 NODE_OPTIONS=--openssl-legacy-provider nuxt generate",
    "build:app:server": "cross-env NUXT_APP=1 NODE_OPTIONS=--openssl-legacy-provider nuxt generate",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
