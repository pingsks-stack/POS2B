    "@nuxtjs/moment": "^1.6.1",
    "capacitor-thermal-printer": "^0.2.5",
    "cross-env": "^5.2.0",
    "moment": "^2.29.1",
    "nuxt": "^2.0.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@nuxtjs/vuetify": "^1.12.1",
    "nodemon": "^1.11.0"
